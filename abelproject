        renderChatHistory();
        if (!currentPlanMarkdown) {
          markdownContent.classList.add('hidden');
          emptyState.classList.remove('hidden');
        }
        $('startBtn')?.addEventListener('click', startWorkspace);
      }
      init();
    })();
  </script>
</body>
</html>

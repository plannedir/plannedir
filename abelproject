      const MODEL_QUEUE = ['gemini-3.5-flash', 'gemini-flash-latest', 'gemini-3.1-flash-lite'];
      const API_BASE = 'https://generativelanguage.googleapis.com/v1beta/models';
      function isRetryableError(m) {
        const l = m.toLowerCase();
        return l.includes('high demand') || l.includes('overloaded') || l.includes('quota') ||
               l.includes('429') || l.includes('503') || l.includes('unavailable') ||
               l.includes('temporarily') || l.includes('no longer available');
      }
      async function tryModel(model, apiKey, contents) {
        const r = await fetch(`${API_BASE}/${model}:generateContent`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-goog-api-key': apiKey },
          body: JSON.stringify({ contents, generationConfig: { temperature: 0.7 } })
        });
        if (!r.ok) {
          const e = await r.json().catch(() => ({}));
          const m = e.error?.message || `HTTP ${r.status}`;
          if (isRetryableError(m)) { const x = new Error(m); x.retryable = true; throw x; }
          throw new Error(m);
        }
        const d = await r.json();
        if (!d.candidates?.[0]?.content?.parts) throw new Error('Model boş yanıt döndü.');
        return d.candidates[0].content.parts[0].text;
      }
      async function generateWithFallback(apiKey, contents) {
        let le = null;
        for (let i = 0; i < MODEL_QUEUE.length; i++) {
          const m = MODEL_QUEUE[i], il = i === MODEL_QUEUE.length - 1;
          if (loaderSub) loaderSub.textContent = il ? `son deneme: ${m}` : `deneniyor: ${m} (${i+1}/${MODEL_QUEUE.length})`;
          try {
            const t = await tryModel(m, apiKey, contents);
            if (headerModel) { headerModel.textContent = m; headerModel.classList.remove('hidden'); }
            if (i > 0) showToast(`${m} ile üretildi`);
            return { text: t, model: m };
          } catch (e) {
            le = e;
            console.warn(`${m} başarısız:`, e.message);
            if (!e.retryable || il) throw e;
          }
        }
        throw le || new Error('Tüm modeller başarısız oldu.');
      }

      function buildPrompt(user, outcome, practices, students, mins, diffs, diff) {
        return `Sen Maarif Modeli uzmanı bir öğretmensin. 5E ve PTÖ uyumlu ders planı üret.
Branş: ${user?.subject || 'Genel'}.
SADECE şu zorluklar: ${diffs.map(d=>'**['+d+']**').join(', ')}.
${diff ? 'Farklılaştırma dahil et.' : ''}
Öğrenci: ${students}, Süre: ${mins} dk.
Öğrenim Çıktıları ve Süreç Bileşenleri: ${outcome}
Öğrenme-Öğretme Uygulamaları: ${practices}
LaTeX kullan, Markdown formatında çıktı ver.`;
      }

      async function generatePlan() {
        const user = loadUserData();
        if (!user?.apiKey) { showToast('API anahtarı yok. Ayarlardan girin.'); $('settingsOverlay').classList.remove('hidden'); return; }
        const outcome = learningOutcome.value.trim();
        if (!outcome) return showToast('Öğrenim çıktısı ve süreç bileşenlerini girin.');
        const diffs = Array.from(document.querySelectorAll('.diff-chip.active')).map(c => c.dataset.label);
        if (diffs.length === 0) return showToast('Zorluk seviyesi seçin.');
        const practices = teachingPractices?.value.trim() || 'Öğretmen, öğrenim çıktısına uygun öğrenme-öğretme uygulamalarını seçer ve öğrencilerin aktif katılımını destekler.';
        const students = studentCount.value || '24';
        const mins = duration.value || '80';
        const diff = toggleDiffBtn.classList.contains('active');
        const prompt = buildPrompt(user, outcome, practices, students, mins, diffs, diff);

        loader.classList.remove('hidden');
        markdownContent.classList.add('hidden');
        $('planNotice')?.classList.add('hidden');
        emptyState.classList.add('hidden');
        loaderText.textContent = 'Plan oluşturuluyor...';
        headerModel.classList.add('hidden');
        if (loaderSub) loaderSub.textContent = '';
        const facts = ['Yapay zekâ öğrenim çıktılarını MEB müfredatına uyarlıyor...', '5E modelindeki Keşfetme adımı öğrencilerin merakını artırır.', 'PTÖ, problem temelli öğrenmenin kısaltmasıdır.'];
        let factIndex = 0;
        if (loaderFact) loaderFact.textContent = facts[0];
        clearInterval(loaderFactTimer);
        loaderFactTimer = setInterval(() => { factIndex = (factIndex + 1) % facts.length; if (loaderFact) loaderFact.textContent = facts[factIndex]; }, 4200);

        try {
          const contents = [{ role: 'user', parts: [{ text: prompt }] }];
          const { text } = await generateWithFallback(user.apiKey, contents);
          currentPlanMarkdown = text;
          markdownContent.innerHTML = marked.parse(text);
          renderMath();
          markdownContent.classList.remove('hidden');
          $('planNotice')?.classList.remove('hidden');
          saveHistoryItem(text);
          addChatMessage('ai', '✅ Yeni ders planı oluşturuldu. Değişiklik isteyebilirsiniz.');
        } catch (e) {
          showToast('Hata: ' + e.message);
        } finally {
          clearInterval(loaderFactTimer);
          loader.classList.add('hidden');
        }
      }

      function setupChoiceGroup(selectId, options) {
        const select = $(selectId);
        if (!select || select.parentElement.querySelector(`[data-choice-target="${selectId}"]`)) return;
        const group = document.createElement('div');
        group.className = 'choice-grid';
        group.dataset.choiceTarget = selectId;
        options.forEach(option => {
          const button = document.createElement('button');
          button.type = 'button';
          button.dataset.choiceValue = option.value;
          button.innerHTML = `<i class="fas ${option.icon}"></i><span>${option.label}</span>`;
          button.addEventListener('click', () => {
            select.value = option.value;
            select.dispatchEvent(new Event('change', { bubbles: true }));
            refreshChoiceGroups();
          });
          group.appendChild(button);
        });
        select.insertAdjacentElement('afterend', group);
        refreshChoiceGroups();
      }
      function refreshChoiceGroups() {
        document.querySelectorAll('[data-choice-target]').forEach(group => {
          const select = $(group.dataset.choiceTarget);
          if (!select) return;
          group.querySelectorAll('button').forEach(button => button.classList.toggle('selected', button.dataset.choiceValue === select.value));
        });

      const SUBJECT_ICONS = { 'Matematik': 'fa-calculator', 'Türkçe': 'fa-pen-nib', 'Türk Dili ve Edebiyatı': 'fa-book-open', 'Fen Bilimleri': 'fa-flask', 'Fizik': 'fa-atom', 'Kimya': 'fa-vial', 'Biyoloji': 'fa-dna', 'Tarih': 'fa-landmark', 'Coğrafya': 'fa-earth-europe', 'İngilizce': 'fa-language', 'Bilişim Teknolojileri': 'fa-laptop-code', 'Görsel Sanatlar': 'fa-palette', 'Müzik': 'fa-music', 'Beden Eğitimi': 'fa-person-running', 'Hayat Bilgisi': 'fa-seedling', 'Sosyal Bilgiler': 'fa-globe-europe', 'Din Kültürü': 'fa-heart', 'Felsefe': 'fa-lightbulb' };
      function renderSubjectsForLevel(subjectId, levelId) {
        const subject = $(subjectId), level = $(levelId);
        if (!subject || !level) return;
        const normalizedLevel = level.value.includes('lkokul') ? 'İlkokul' : (level.value.includes('Lise') ? 'Lise' : 'Ortaokul');
        const courses = SUBJECTS_BY_LEVEL[normalizedLevel];
        const previous = subject.value;
        subject.innerHTML = courses.map(course => `<option value="${course}">${course}</option>`).join('');
        subject.value = courses.includes(previous) ? previous : courses[0];
        const group = document.querySelector(`[data-choice-target="${subjectId}"]`);
        if (!group) return;
        group.innerHTML = '';
        courses.forEach(course => {
          const button = document.createElement('button');
          button.type = 'button';
          button.dataset.choiceValue = course;
          button.innerHTML = `<i class="fas ${SUBJECT_ICONS[course] || 'fa-book'}"></i><span>${course}</span>`;
          button.addEventListener('click', () => { subject.value = course; refreshChoiceGroups(); });
          group.appendChild(button);
        });
        refreshChoiceGroups();
      }

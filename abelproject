      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.7rem 1.4rem; border-radius: 3rem;
      font-weight: 500; cursor: pointer; transition: all var(--transition);
      border: 1px solid var(--border); background: var(--surface);
      color: var(--text); font-size: 0.85rem;
      backdrop-filter: blur(12px);
    }
    .btn:hover {
      background: var(--accent-light);
      border-color: var(--accent);
      color: var(--accent);
      transform: translateY(-1px);
      box-shadow: var(--shadow-sm);
    }
    .btn-primary {
      background: var(--text); color: var(--bg); border: none; font-weight: 600;
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    }
    .btn-primary:hover {
      background: var(--accent); color: white;
      box-shadow: 0 8px 24px var(--accent-glow);
    }
    .btn-ghost {
      background: transparent; border: none; backdrop-filter: none;
    }
    .btn-ghost:hover { background: var(--accent-light); }
    .btn-sm { padding: 0.4rem 0.9rem; font-size: 0.75rem; }
    .input {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 2px solid var(--border);
      padding: 0.6rem 0;
      font-size: 0.9rem;
      outline: none;
      transition: border-color var(--transition);
      color: var(--text);
      font-family: inherit;
    }
    .input:focus { border-bottom-color: var(--accent); }
    .textarea {
      width: 100%;
      background: rgba(255,255,255,0.3);
      backdrop-filter: blur(8px);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 0.9rem 1rem;
      font-size: 0.9rem;
      outline: none;
      resize: vertical;
      min-height: 90px;
      color: var(--text);
      font-family: inherit;
      transition: all var(--transition);
    }
    .textarea:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px var(--accent-light);
    }
    .chip {
      display: inline-flex; align-items: center; gap: 0.3rem;
      padding: 0.45rem 1rem; border-radius: 2rem;
      border: 1px solid var(--border); background: var(--surface);
      cursor: pointer; font-size: 0.78rem; font-weight: 500;
      transition: all var(--transition);
      backdrop-filter: blur(8px);
    }
    .chip:hover { border-color: var(--border-strong); background: var(--surface-hover); }
    .chip.active {
      background: var(--accent-light); border-color: var(--accent); color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-light);
    }
    #markdownContent {
      line-height: 1.9;
      font-size: 0.95rem;
      color: var(--text-secondary);
      padding: 1rem;
    }
    #markdownContent h1 {
      font-size: 2.2rem; font-weight: 800; color: var(--text);
      margin-top: 2.5rem; margin-bottom: 1.2rem; letter-spacing: -0.5px;
    }
    #markdownContent h1:first-child { margin-top: 0; }
    #markdownContent h2 {
      font-size: 1.5rem; font-weight: 700; color: var(--text);
      margin-top: 2rem; margin-bottom: 1rem;
      padding-bottom: 0.8rem; border-bottom: 1.5px solid var(--border);
    }
    #markdownContent h3 {
      font-size: 1.2rem; font-weight: 600; color: var(--text);
      margin-top: 1.6rem; margin-bottom: 0.8rem;
    }
    #markdownContent p { margin-bottom: 1.2rem; }
    #markdownContent ul, #markdownContent ol {
      margin-left: 1.2rem; margin-bottom: 1.2rem;
    }
    #markdownContent li { margin-bottom: 0.6rem; padding-left: 0.3rem; }
    #markdownContent li::marker { color: var(--accent); }
    #markdownContent strong { color: var(--text); font-weight: 600; }
    #markdownContent code {
      background: rgba(0,0,0,0.04); padding: 0.15rem 0.5rem;
      border-radius: 0.4rem; font-family: 'JetBrains Mono', monospace;
      font-size: 0.85em; color: var(--accent);
    }
    .dark #markdownContent code { background: rgba(255,255,255,0.06); }
    #markdownContent pre {
      background: var(--text); color: var(--bg);
      border-radius: var(--radius-sm); padding: 1.2rem 1.5rem;
      overflow-x: auto; margin: 1.2rem 0;
      font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;
      line-height: 1.6;
    }
    #markdownContent table {
      width: 100%; border-collapse: collapse; margin: 1.2rem 0;
      border-radius: var(--radius-sm); overflow: hidden;
      border: 1px solid var(--border);
    }
    #markdownContent thead th {
      background: var(--text); color: var(--bg);
      padding: 0.8rem 1rem; text-align: left; font-weight: 600; font-size: 0.8rem;
    }
    #markdownContent tbody td {
      padding: 0.7rem 1rem; border-bottom: 1px solid var(--border); font-size: 0.85rem;
    }
    #markdownContent blockquote {
      border-left: 4px solid var(--accent);
      padding: 0.8rem 1.2rem; margin: 1.2rem 0;
      background: var(--accent-light); border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      font-style: italic; color: var(--text-secondary);
    }
    .chat-message {
      padding: 0.7rem 1rem; border-radius: var(--radius-sm);
      margin-bottom: 0.6rem; max-width: 85%;
      font-size: 0.85rem; line-height: 1.5;
      word-wrap: break-word;
    }
    .chat-user {
      background: var(--accent-light); border: 1px solid rgba(232,89,12,0.15);
      align-self: flex-end; margin-left: auto;
    }
    .chat-ai {
      background: var(--surface); border: 1px solid var(--border);
      align-self: flex-start;
    }
    .typing-indicator {
      display: flex; gap: 0.3rem; padding: 0.5rem 1rem;
      align-self: flex-start;
    }
    .typing-dot {
      width: 0.4rem; height: 0.4rem; border-radius: 50%;
      background: var(--text-secondary);
      animation: typingBounce 1.4s infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typingBounce {
      0%,60%,100% { opacity: 0.3; transform: translateY(0); }
      30% { opacity: 1; transform: translateY(-6px); }
    }
    .toast {
      position: fixed; bottom: 2rem; right: 2rem;
      background: var(--text); color: var(--bg);
      padding: 0.9rem 1.6rem; border-radius: 3rem;
      font-weight: 500; font-size: 0.85rem;
      transform: translateY(120px); opacity: 0;
      transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
      z-index: 9999; box-shadow: var(--shadow-lg);
      backdrop-filter: blur(16px);
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.3);
      backdrop-filter: blur(8px); z-index: 100;
      display: flex; align-items: center; justify-content: center;
    }
    .modal {
      background: var(--surface-strong);
      backdrop-filter: blur(32px);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-xl);
      padding: 2rem; max-width: 480px; width: 90%;
      box-shadow: var(--shadow-lg);
      animation: fadeUp 0.4s ease;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .onboarding-card {
      background: var(--surface-strong);
      backdrop-filter: blur(32px);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-xl);
      padding: 3rem 2.5rem;
      max-width: 540px; width: 90%;
      box-shadow: var(--shadow-lg);
      text-align: center;
      animation: fadeUp 0.6s ease;
    }
    .section-title {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.8px;
      color: var(--text-secondary); margin-bottom: 0.5rem; font-weight: 600;
    }
    @media (max-width: 1200px) {
      .workspace { flex-direction: column; height: auto; }
      .panel { margin: 0.4rem 0; max-height: none; }
      .panel-left, .panel-right { width: 100%; }
      .panel-center { min-height: 60vh; }
    }
    @media (max-width: 640px) {
      .workspace { padding: 0.3rem; gap: 0.3rem; }
      .panel { border-radius: var(--radius); padding: 0.8rem; }
      .btn { padding: 0.5rem 1rem; font-size: 0.8rem; }
    }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 10px; }
    @media (max-width: 768px) {
      .panel-left { display: none; }
      .panel-left.open { display: flex; position: fixed; top: 0; left: 0; height: 100vh; z-index: 50; width: 85%; }
      .panel-right { display: none; }
      .panel-right.open { display: flex; position: fixed; top: 0; right: 0; height: 100vh; z-index: 50; width: 85%; }
    }
    :root {
      --bg: #f9f7f2;
      --bg-gradient: radial-gradient(ellipse at 30% 10%, #fffaf5 0%, #f9f7f2 58%, #f4f0ea 100%);

  <style>
    :root {
      --bg: #f5f2ed;
      --bg-gradient: radial-gradient(ellipse at 30% 20%, #fef9f2 0%, #f5f2ed 60%, #f0ebe0 100%);
      --surface: rgba(255,255,255,0.65);
      --surface-strong: rgba(255,255,255,0.85);
      --surface-hover: rgba(255,255,255,0.8);
      --text: #1a1a1a;
      --text-secondary: #6b6b6b;
      --border: rgba(0,0,0,0.06);
      --border-strong: rgba(0,0,0,0.1);
      --accent: #e8590c;
      --accent-light: rgba(232,89,12,0.08);
      --accent-glow: rgba(232,89,12,0.2);
      --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
      --shadow-md: 0 8px 32px rgba(0,0,0,0.06);
      --shadow-lg: 0 20px 48px rgba(0,0,0,0.08);
      --radius-sm: 1rem;
      --radius: 1.5rem;
      --radius-lg: 2rem;
      --radius-xl: 2.5rem;
      --transition: 0.3s cubic-bezier(0.16,1,0.3,1);
    }
    .dark {
      --bg: #0a0a0a;
      --bg-gradient: radial-gradient(ellipse at 30% 20%, #1a1a1a 0%, #0a0a0a 60%, #000 100%);
      --surface: rgba(30,30,30,0.7);
      --surface-strong: rgba(40,40,40,0.85);
      --surface-hover: rgba(50,50,50,0.8);
      --text: #f0f0f0;
      --text-secondary: #999;
      --border: rgba(255,255,255,0.06);
      --border-strong: rgba(255,255,255,0.1);
      --accent: #ff7b3d;
      --accent-light: rgba(255,123,61,0.1);
      --accent-glow: rgba(255,123,61,0.25);
      --shadow-sm: 0 2px 8px rgba(0,0,0,0.2);
      --shadow-md: 0 8px 32px rgba(0,0,0,0.3);
      --shadow-lg: 0 20px 48px rgba(0,0,0,0.4);
    }
    * { box-sizing: border-box; }
    body {
      font-family: 'DM Sans', 'Inter', sans-serif;
      background: var(--bg-gradient);
      color: var(--text);
      margin: 0;
      min-height: 100vh;
      transition: background 0.5s, color 0.3s;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      line-height: 1.7;
    }
    body::before, body::after {
      content: '';
      position: fixed;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.4;
      z-index: 0;
      pointer-events: none;
    }
    body::before {
      width: 600px; height: 600px;
      background: rgba(255,180,140,0.25);
      top: -15%; right: -10%;
      animation: floatA 20s infinite alternate;
    }
    body::after {
      width: 700px; height: 700px;
      background: rgba(180,200,255,0.2);
      bottom: -15%; left: -10%;
      animation: floatB 24s infinite alternate;
    }
    @keyframes floatA {
      0% { transform: translate(0,0) scale(1); }
      100% { transform: translate(60px,-50px) scale(1.1); }
    }
    @keyframes floatB {
      0% { transform: translate(0,0) scale(1); }
      100% { transform: translate(-50px,40px) scale(1.15); }
    }
    .workspace {
      display: flex;
      width: 100%;
      height: 100vh;
      position: relative;
      z-index: 1;
      padding: 0.5rem;
      gap: 0.5rem;
    }
    .panel {
      background: var(--surface);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-md);
      border-radius: var(--radius-lg);
      overflow-y: auto;
      transition: all var(--transition);
      display: flex;
      flex-direction: column;
    }
    .panel:hover {
      background: var(--surface-hover);
      box-shadow: var(--shadow-lg);
    }
    .panel-left { width: 320px; flex-shrink: 0; }
    .panel-center { flex: 1; min-width: 0; }
    .panel-right { width: 340px; flex-shrink: 0; }

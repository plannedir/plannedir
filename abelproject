    }
    body::before { width: 520px; height: 520px; background: #ffd3b6; opacity: .28; top: -16%; right: -10%; filter: blur(100px); }
    body::after { width: 620px; height: 620px; background: #d6e4ff; opacity: .22; bottom: -18%; left: -12%; filter: blur(100px); }
    .workspace {
      width: min(1480px, 100%);
